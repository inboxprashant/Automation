{
  "name": "youtube-shorts-automation",
  "version": "1.0.0",
  "description": "Production-ready YouTube Shorts automation system",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "workflow": "node scripts/run_workflow.js",
    "batch": "node scripts/run_batch.js",
    "scheduler": "node src/scheduler/cron.js",
    "scheduler:status": "node scripts/scheduler_status.js",
    "analytics": "node scripts/run_analytics.js",
    "dashboard": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build",
    "generate": "node src/pipeline/run.js",
    "check:config": "node scripts/check_config.js",
    "generate:script": "node scripts/generate_script.js",
    "generate:voice": "node scripts/generate_voice.js",
    "generate:captions": "node scripts/generate_captions.js",
    "generate:video": "node scripts/generate_video.js",
    "fetch:clips": "node scripts/fetch_clips.js",
    "generate:thumbnail": "node scripts/generate_thumbnail.js",
    "upload:video": "node scripts/upload_video.js",
    "test:email": "node scripts/test_email.js",
    "find:trends": "node scripts/find_trends.js",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "dotenv": "^16.4.5",
    "form-data": "^4.0.0",
    "google-trends-api": "^4.9.2",
    "googleapis": "^140.0.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
    "openai": "^4.47.1",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
