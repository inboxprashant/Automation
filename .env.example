# ════════════════════════════════════════════════════════════
#  YouTube Shorts Automation — Environment Configuration
#  Copy this file to .env and fill in every required value.
#  Never commit .env to version control.
# ════════════════════════════════════════════════════════════

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Required. Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional. Defaults to gpt-4o
OPENAI_MODEL=gpt-4o

# ─── ElevenLabs ──────────────────────────────────────────────────────────────
# Required. Get yours at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=...

# Optional. Voice ID from your ElevenLabs account. Defaults to Rachel.
# Browse voices at https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ─── YouTube Data API v3 ─────────────────────────────────────────────────────
# Required. Create OAuth2 credentials at https://console.cloud.google.com
YOUTUBE_CLIENT_ID=...
YOUTUBE_CLIENT_SECRET=...

# Optional. Must match the redirect URI registered in Google Cloud Console.
YOUTUBE_REDIRECT_URI=http://localhost:3000/oauth2callback

# Required. Run `node scripts/get_token.js` once to obtain this.
YOUTUBE_REFRESH_TOKEN=...

# Required. The exact name of your YouTube channel (used in notifications).
CHANNEL_NAME=My Shorts Channel

# ─── Gmail SMTP ──────────────────────────────────────────────────────────────
# Required. Gmail address used to send notifications.
GMAIL_USER=you@gmail.com

# Required. 16-character App Password (NOT your regular Gmail password).
# Generate one at: https://myaccount.google.com/apppasswords
# Requires 2-Step Verification to be enabled on the account.
GMAIL_PASS=xxxx xxxx xxxx xxxx

# Optional. Who receives the notifications. Defaults to GMAIL_USER.
NOTIFY_EMAIL=you@gmail.com

# ─── Pipeline ────────────────────────────────────────────────────────────────
# Optional. Niche for script generation.
# Allowed: tech | finance | motivation | facts | health | history
TOPIC_CATEGORY=tech

# Optional. How many Shorts to publish per slot. Default: 1. Max: 10.
SHORTS_PER_DAY=1

# Optional. Upload times — comma-separated HH:MM. Default: 09:00, 15:00, 20:00
# These are interpreted in SCHEDULE_TIMEZONE.
UPLOAD_TIMES=09:00,15:00,20:00

# Optional. IANA timezone for the scheduler. Default: UTC
# Examples: America/New_York | Europe/London | Asia/Tokyo | Australia/Sydney
SCHEDULE_TIMEZONE=UTC

# Optional. Per-slot niche override (comma-separated, same count as UPLOAD_TIMES).
# Leave a slot blank to use TOPIC_CATEGORY. e.g. "ai_tools,,money_facts"
SLOT_NICHES=

# Optional. Legacy single cron expression (used if UPLOAD_TIMES is not set).
CRON_SCHEDULE=0 9 * * *

# Optional. Time label shown in notifications (e.g. "09:00 UTC").
VIDEO_POST_TIME=09:00 UTC

# ─── Stock Media APIs ────────────────────────────────────────────────────────
# Optional but strongly recommended — without these, the video builder
# uses only clips already in assets/backgrounds/.
#
# Pexels: https://www.pexels.com/api/  (free, 200 req/hour)
PEXELS_API_KEY=...

# Pixabay: https://pixabay.com/api/docs/  (free, 100 req/min)
PIXABAY_API_KEY=...

# Optional. How many stock clips to fetch per video. Default: 6
MEDIA_TARGET_CLIPS=6

# ─── Paths ───────────────────────────────────────────────────────────────────
# Optional. Where finished MP4s are saved. Default: ./output
OUTPUT_FOLDER=./output

# Optional. Where background video clips are stored. Default: ./assets
ASSETS_DIR=./assets

# Optional. Scratch space for intermediate files. Default: ./temp
TEMP_DIR=./temp

# ─── Logging & Runtime ───────────────────────────────────────────────────────
# Optional. debug | info | warn | error. Default: info
LOG_LEVEL=info

# Optional. development | production. Default: production
NODE_ENV=production

# Optional. Port for the health check server (GET /health /ready /metrics)
HEALTH_PORT=3002
